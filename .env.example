DATABASE_URL=postgres://bustracker:bustracker@localhost:55432/bustracker
STADIA_API_KEY=
NODE_ENV=development
LOG_LEVEL=INFO

# GTFS-Realtime (Ticket 104 / 107) — file:// not supported; use http(s) or leave blank for tests
GTFS_RT_VEHICLE_POSITIONS_URL=
GTFS_RT_TRIP_UPDATES_URL=
GTFS_FEED_AUTH_HEADER=
GTFS_RT_FEED_NAME=default
POLL_INTERVAL_MS=10000
FEED_FAILURE_ALERT_THRESHOLD=6
FEED_STALE_SECONDS=120

# Dummy Perth/Kinross operator feed (fixtures/operator-dummy) — local soak / Sprint 2 only.
# Does not satisfy Ticket 109 Stage C (needs real operator AVL). Start with: npm run dummy:rt
# GTFS_RT_VEHICLE_POSITIONS_URL=http://127.0.0.1:8099/gtfs-rt/vehicle-positions.pb
# GTFS_RT_TRIP_UPDATES_URL=http://127.0.0.1:8099/gtfs-rt/trip-updates.pb
# GTFS_RT_FEED_NAME=dummy-perth-kinross
# Optional denser demo clock (0–23): DUMMY_RT_SIMULATE_HOUR=12

# Quality thresholds (Ticket 105)
QUALITY_STALE_SECONDS=60
QUALITY_VERY_STALE_SECONDS=300
QUALITY_OFF_ROUTE_METRES=150
QUALITY_OFF_ROUTE_CONSECUTIVE=3
QUALITY_TRIP_ENDED_MINUTES=30
QUALITY_MAX_SPEED_MPS=40
QUALITY_JUMP_METRES=2000
QUALITY_JUMP_SECONDS=30
QUALITY_BASELINE_GAP_SECONDS=600
ARRIVAL_STALE_SECONDS=180
MAX_BBOX_SQ_KM=50000
